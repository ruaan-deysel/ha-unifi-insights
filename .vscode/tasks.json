{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Home Assistant (Development Mode)",
      "type": "shell",
      "command": "./scripts/develop",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": [],
      "isBackground": true
    },
    {
      "label": "Run Tests",
      "type": "shell",
      "command": "${command:python.interpreterPath} -m pytest",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "Run Tests with Coverage",
      "type": "shell",
      "command": "${command:python.interpreterPath} -m pytest --cov=custom_components.unifi_insights --cov-branch --cov-report=term-missing --cov-report=html --cov-report=xml",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "Lint (Ruff Format + Check)",
      "type": "shell",
      "command": "./scripts/lint",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "Lint Check (Read-Only)",
      "type": "shell",
      "command": "${command:python.interpreterPath} -m ruff check .",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "Type Check",
      "type": "shell",
      "command": "${command:python.interpreterPath} -m mypy custom_components/unifi_insights",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "Check All (Type + Lint + Tests)",
      "type": "shell",
      "command": "pre-commit run --all-files && ${command:python.interpreterPath} -m pytest",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "Pre-commit (All Hooks)",
      "type": "shell",
      "command": "pre-commit run --all-files",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "Install Requirements",
      "type": "shell",
      "command": "./scripts/setup",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "Validate Manifest",
      "type": "shell",
      "command": "${command:python.interpreterPath} -c \"import json; json.load(open('custom_components/unifi_insights/manifest.json')); print('manifest.json is valid')\"",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    }
  ]
}
