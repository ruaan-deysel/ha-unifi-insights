#!/usr/bin/env python3
"""Diagnostic: test which Protect API endpoints return firmware version.

Usage:
    python3 script/test-firmware
"""

from __future__ import annotations

import asyncio
import json
import ssl
import sys
from pathlib import Path

import aiohttp

# Load credentials from script/.env
env_path = Path(__file__).resolve().parent / ".env"
lines = [l.strip() for l in env_path.read_text().strip().splitlines() if l.strip()]
host = lines[0]
api_key = None
for line in lines[1:]:
    if line.lower().startswith(("unifi", "#", "//")):
        continue
    api_key = line
    break

BASE = f"https://{host}"
HEADERS = {"X-API-KEY": api_key, "Accept": "application/json"}


async def test_endpoint(session: aiohttp.ClientSession, path: str, label: str) -> dict | list | None:
    """Test an API endpoint and print firmware-related fields."""
    url = f"{BASE}{path}"
    print(f"\n{'='*70}")
    print(f"  {label}")
    print(f"  GET {path}")
    print(f"{'='*70}")
    try:
        async with session.get(url, headers=HEADERS, ssl=False) as resp:
            if resp.status != 200:
                print(f"  Status: {resp.status}")
                text = await resp.text()
                print(f"  Body: {text[:200]}")
                return None
            data = await resp.json()
            return data
    except Exception as e:
        print(f"  Error: {e}")
        return None


def extract_firmware_fields(device: dict, indent: int = 4) -> None:
    """Extract and display firmware-related fields from a device dict."""
    pad = " " * indent
    name = device.get("name") or device.get("hostname") or device.get("mac") or "?"
    print(f"{pad}{name}:")
    for key in ("firmwareVersion", "firmware_version", "version",
                "firmwareBuild", "firmware_build", "fwVersion", "fw_version",
                "firmwareRevision", "firmware", "softwareVersion"):
        if key in device:
            print(f"{pad}  {key}: {device[key]}")
    # Also check nested
    if "firmwareInfo" in device:
        print(f"{pad}  firmwareInfo: {device['firmwareInfo']}")


async def main() -> None:
    print(f"Host: {host}")
    print(f"API Key: {api_key[:8]}...")

    connector = aiohttp.TCPConnector(ssl=False)
    async with aiohttp.ClientSession(connector=connector) as session:

        # 1. Integration API - cameras (what we currently use)
        data = await test_endpoint(
            session,
            "/proxy/protect/integration/v1/cameras",
            "Protect Integration API - Cameras (current)"
        )
        if data:
            items = data if isinstance(data, list) else data.get("data", data) if isinstance(data, dict) else []
            if isinstance(items, list):
                print(f"  Found {len(items)} cameras")
                for cam in items:
                    extract_firmware_fields(cam)
                    # Show ALL top-level keys for first camera
                    if cam == items[0]:
                        print(f"      All keys: {sorted(cam.keys())}")
            else:
                print(f"  Unexpected response type: {type(items)}")

        # 2. Legacy Protect API - bootstrap
        data = await test_endpoint(
            session,
            "/proxy/protect/api/bootstrap",
            "Legacy Protect API - Bootstrap"
        )
        if data:
            if isinstance(data, dict):
                print(f"  Top-level keys: {sorted(data.keys())}")
                for device_type in ("cameras", "lights", "sensors", "chimes", "viewers"):
                    devices = data.get(device_type, [])
                    if devices:
                        print(f"\n  {device_type} ({len(devices)}):")
                        for dev in devices:
                            if isinstance(dev, dict):
                                extract_firmware_fields(dev, 6)

                # NVR
                nvr = data.get("nvr")
                if isinstance(nvr, dict):
                    print(f"\n  NVR:")
                    extract_firmware_fields(nvr, 6)

        # 3. Legacy Protect API - cameras
        data = await test_endpoint(
            session,
            "/proxy/protect/api/cameras",
            "Legacy Protect API - Cameras"
        )
        if data:
            items = data if isinstance(data, list) else data.get("data", []) if isinstance(data, dict) else []
            if isinstance(items, list):
                print(f"  Found {len(items)} cameras")
                for cam in items:
                    if isinstance(cam, dict):
                        extract_firmware_fields(cam)
                        if cam == items[0]:
                            print(f"      All keys: {sorted(cam.keys())}")

        # 4. Integration API - NVRs
        data = await test_endpoint(
            session,
            "/proxy/protect/integration/v1/nvrs",
            "Protect Integration API - NVRs (current)"
        )
        if data:
            items = data if isinstance(data, list) else data.get("data", data) if isinstance(data, dict) else []
            if isinstance(items, list):
                for nvr in items:
                    if isinstance(nvr, dict):
                        extract_firmware_fields(nvr)
                        print(f"      All keys: {sorted(nvr.keys())}")

        # 5. Legacy Protect API - NVR
        data = await test_endpoint(
            session,
            "/proxy/protect/api/nvr",
            "Legacy Protect API - NVR"
        )
        if data:
            if isinstance(data, dict):
                extract_firmware_fields(data)
                # Show firmware-related subset of keys
                fw_keys = [k for k in sorted(data.keys()) if "firm" in k.lower() or "version" in k.lower() or "fw" in k.lower()]
                print(f"      Firmware-related keys: {fw_keys}")

    print("\n" + "="*70)
    print("  Done!")
    print("="*70)


if __name__ == "__main__":
    asyncio.run(main())
